    <string name="status_caution_rec">CAUTION: REST NEEDED</string>
    <string name="status_overload_rec">OVERLOAD DETECTED</string>
    <string name="hrv_label">HRV</string>
    <string name="sleep_label">SLEEP</string>
    <string name="mins">mins</string>
    <string name="recovery_optimal_desc">Your HRV is stable and consistent with your current training load. You are ready for high-intensity work.</string>
    <string name="recovery_caution_desc">Your HRV has dropped by more than 10%. Your body is showing signs of stress. Consider an active recovery day.</string>
    <string name="recovery_overload_desc">HRV drop combined with high fatigue (ATL) detected. High risk of non-functional overreaching. Take a full rest day.</string>
    <string name="hrv_desc">"Heart Rate Variability (HRV): Measures the variation in time between consecutive heartbeats. Higher HRV typically indicates better recovery and readiness."</string>
    <string name="sleep_desc">Total sleep duration recorded. Quality sleep is the most effective recovery tool for any athlete.</string>
