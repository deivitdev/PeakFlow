    <string name="path_recover">RECOVER</string>
    <string name="path_build_desc">High intensity or volume to increase your fitness level.</string>
    <string name="path_maintain_desc">Moderate load to keep your current fitness without excessive fatigue.</string>
    <string name="path_recover_desc">Active recovery or rest to clear fatigue and regain freshness.</string>
    <string name="fueling_forecast">FUELING FORECAST</string>
    <string name="fueling_desc">This session will expend ~%1$sg of glycogen. Prioritize carbohydrates.</string>
    <string name="tss_target_label">TSS TARGET</string>
    <string name="form_forecast">FORM: %1$s</string>
    <string name="estimate_cycling">~%1$s Cycling</string>
    <string name="estimate_running">~%1$s Running</string>
    <string name="fueling_strategy_loading">"Critical Session: Glycogen loading required. High carb intake recommended 24h prior."</string>
    <string name="fueling_strategy_performance">"Performance Focus: Ensure steady carbohydrate intake during and after the session."</string>
    <string name="fueling_strategy_maintenance">"Standard Fueling: Maintain balanced nutrition. Normal carb intake is sufficient."</string>
    <string name="fueling_strategy_recovery">"Recovery Boost: Focus on glycogen replenishment to speed up muscle repair."</string>
    <string name="alert_strength_neglect">Priority: Strength &amp; Mobility. You haven't recorded a strength session in the last 7 days.</string>
    <string name="alert_high_frequency">"High Frequency detected. Ensure your 'Recover' path includes total rest to avoid burnout."</string>
    <string name="tsb_guide_title">GUIDE TO TRAINING STATES (TSB)</string>
    <string name="tsb_guide_learn_more">How to interpret my form?</string>
    <string name="tsb_range_fresh_title">FRESH / PEAK FORM</string>
    <string name="tsb_range_fresh_desc">Greater than +5: Ideal for racing or testing. Your body has fully absorbed the training load.</string>
    <string name="tsb_range_recovery_title">RECOVERY</string>
    <string name="tsb_range_recovery_desc">0 to +5: Transition state. Well-rested but starting to lose adaptations if you stay here too long.</string>
    <string name="tsb_range_neutral_title">NEUTRAL</string>
    <string name="tsb_range_neutral_desc">0 to -10: Maintenance phase. Training but not enough to drive significant gains or fatigue.</string>
    <string name="tsb_range_optimal_title">OPTIMAL (SWEET SPOT)</string>
    <string name="tsb_range_optimal_desc">-10 to -30: Where the magic happens. You are stressing the body enough to improve constantly.</string>
    <string name="tsb_range_risk_title">OVERREACHING RISK</string>
    <string name="tsb_range_risk_desc">Less than -30: Warning sign. You are accumulating fatigue much faster than you can recover.</string>
    <string name="coach_guide_title">GUIDE TO TRAINING PATHS</string>
    <string name="coach_guide_learn_more">What do these paths mean?</string>
    <string name="coach_path_build_title">BUILD (DEVELOPMENT)</string>
    <string name="coach_path_build_desc">Calculates the load needed to reach a TSB of -20. This pushes your limits to drive long-term fitness (CTL) adaptations. Best used in mid-training blocks.</string>
    <string name="coach_path_maintain_title">MAINTAIN (CONSISTENCY)</string>
    <string name="coach_path_maintain_desc">Calculates the load needed to stay around -5 TSB. This keeps your current fitness steady while allowing for moderate recovery. Ideal for busy weeks.</string>
    <string name="coach_path_recover_title">RECOVER (FRESHNESS)</string>
    <string name="coach_path_recover_desc">Suggests a very low load (TSS 15) to allow your fatigue (ATL) to drop significantly. Use this when feeling drained or preparing for a big event.</string>
    <string name="tss_guide_title">WHAT IS TSS?</string>
    <string name="tss_guide_desc">Training Stress Score (TSS) measures how much "work" you do. 100 TSS equals 1 hour of maximum effort. It combines duration and intensity to give you a single number for your daily "stress budget".</string>
    <string name="ramp_rate_label">IMPROVEMENT SPEED</string>
    <string name="ramp_rate_desc">"Ramp Rate: Measures how fast your fitness (CTL) is increasing per week. Stable growth prevents injuries."</string>
    <string name="ramp_status_maintenance">MAINTENANCE</string>
    <string name="ramp_status_productive">PRODUCTIVE</string>
    <string name="ramp_status_intense">INTENSE</string>
    <string name="ramp_status_risky">HIGH RISK</string>
    <string name="ramp_pts_per_week">+%1$s pts/week</string>
    <string name="ramp_rate_guide_title">GUIDE TO IMPROVEMENT SPEED (RAMP RATE)</string>
    <string name="ramp_rate_learn_more">What is my progression speed?</string>
    <string name="ramp_level_maintenance">MAINTENANCE: You are keeping your fitness steady. Good for recovery phases.</string>
    <string name="ramp_level_productive">PRODUCTIVE: The "Sweet Spot" for safe and consistent fitness gains.</string>
    <string name="ramp_level_intense">INTENSE: High workload. Ensure you are getting enough sleep and nutrition.</string>
    <string name="ramp_level_risky">HIGH RISK: You are increasing load too fast. High risk of injury or burnout.</string>
