    <string name="path_maintain">MANTENIMIENTO</string>
    <string name="path_recover">RECUPERACIÓN</string>
    <string name="path_build_desc">Alta intensidad o volumen para aumentar tu nivel de forma.</string>
    <string name="path_maintain_desc">Carga moderada para mantener tu forma actual sin fatiga excesiva.</string>
    <string name="path_recover_desc">Recuperación activa o descanso para limpiar la fatiga y ganar frescura.</string>
    <string name="fueling_forecast">PREVISIÓN DE COMBUSTIBLE</string>
    <string name="fueling_desc">Esta sesión consumirá ~%1$sg de glucógeno. Prioriza los carbohidratos.</string>
    <string name="tss_target_label">OBJETIVO TSS</string>
    <string name="form_forecast">FORMA: %1$s</string>
    <string name="fueling_strategy_loading">"Sesión Crítica: Carga de glucógeno requerida. Se recomienda alta ingesta de carbohidratos 24h antes."</string>
    <string name="fueling_strategy_performance">"Enfoque Rendimiento: Asegura una ingesta constante de carbohidratos durante y después de la sesión."</string>
    <string name="fueling_strategy_maintenance">"Nutrición Estándar: Mantén una dieta equilibrada. La ingesta normal de carbohidratos es suficiente."</string>
    <string name="fueling_strategy_recovery">"Impulso Recuperación: Prioriza la reposición de glucógeno para acelerar la reparación muscular."</string>
    <string name="alert_strength_neglect">Prioridad: Fuerza y Movilidad. No has registrado una sesión de fuerza en los últimos 7 días.</string>
    <string name="alert_high_frequency">"Frecuencia Alta detectada. Asegúrate de que tu camino de 'Recuperación' incluya descanso total."</string>
    <string name="tsb_guide_title">GUÍA DE ESTADOS DE FORMA (TSB)</string>
    <string name="tsb_guide_learn_more">¿Cómo interpretar mi estado?</string>
    <string name="tsb_range_fresh_title">FRESCO / PICO DE FORMA</string>
    <string name="tsb_range_fresh_desc">Mayor a +5: Ideal para competir o test de FTP. Tu cuerpo ha asimilado totalmente la carga.</string>
    <string name="tsb_range_recovery_title">RECUPERACIÓN</string>
    <string name="tsb_range_recovery_desc">0 a +5: Estado de transición. Descansado pero empezando a perder adaptaciones si te quedas aquí mucho tiempo.</string>
    <string name="tsb_range_neutral_title">NEUTRAL</string>
    <string name="tsb_range_neutral_desc">0 a -10: Fase de mantenimiento. Entrenando pero sin generar fatiga productiva ni recuperar del todo.</string>
    <string name="tsb_range_optimal_title">ÓPTIMO (PUNTO DULCE)</string>
    <string name="tsb_range_optimal_desc">-10 a -30: Donde ocurre la magia. Estresas al cuerpo lo suficiente para mejorar constantemente.</string>
    <string name="tsb_range_risk_title">RIESGO DE SOBREESFUERZO</string>
    <string name="tsb_range_risk_desc">Menor a -30: Señal de alerta. Acumulas fatiga mucho más rápido de lo que puedes recuperar.</string>
