    <string name="peakflow_insight">CONSEJO PEAKFLOW</string>
    <string name="polarization_desc">"Modelo 80/20: El 80% debe ser intensidad BAJA (Azul) y el 20% intensidad ALTA (Rojo). La 'Zona Gris' (Gris) es el término medio que genera fatiga sin tantos beneficios; evítala en tus sesiones suaves."</string>
    <string name="metabolic_desc">"Uso de combustible: Muestra una estimación de glucógeno (carbos) y grasas quemados según la intensidad. La alta intensidad depende más del glucógeno y requiere más recuperación."</string>
    <string name="grey_zone_recommendation">"Estás pasando un %1$s%% de tu tiempo en la 'Zona Gris'. Considera hacer tus sesiones suaves más suaves (Z2) y tus sesiones intensas más intensas (Z4/Z5)."</string>
    <string name="hydration_recommendation">"Condiciones de calor detectadas. Basado en tu esfuerzo, te recomendamos reponer ~%1$sL de agua con electrolitos."</string>
